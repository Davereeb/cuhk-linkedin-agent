# Copy this file to .env and fill in your real API keys.
# Never commit .env to Git.

# ── Required ──────────────────────────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-your-dashscope-key-here
SERPER_API_KEY=your-serper-key-here

# ── Optional — image generation ───────────────────────────────────────────────
# Enables Google Gemini Imagen 3 (recommended — best image quality)
# Get a free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Enables z-image-turbo fallback via DashScope International endpoint
DASHSCOPE_INTL_API_KEY=
